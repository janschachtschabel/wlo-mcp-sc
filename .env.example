# Repository (edu-sharing) base URL. Defaults to the WLO production
# redaction instance. For a staging deployment, set this to the staging
# edu-sharing host — the REST and frontend paths are identical between
# the two environments. /edu-sharing is auto-appended if missing.
#
# Examples:
#   WLO_REPOSITORY_URL=https://redaktion.openeduhub.net/edu-sharing       # prod
#   WLO_REPOSITORY_URL=https://repository.staging.openeduhub.net           # staging (auto-appends /edu-sharing)
#   WLO_REPOSITORY_URL=https://repository.staging.openeduhub.net/edu-sharing  # staging (explicit)
WLO_REPOSITORY_URL=https://redaktion.openeduhub.net/edu-sharing

# Optional: override the root collection nodeId. Default is the canonical
# WLO root which is identical on the production and staging mirror today.
# Set this only if your custom repository uses a different root.
# WLO_ROOT_COLLECTION_ID=5e40e372-735c-4b17-bbf7-e827a5702b57

# Optional: nodeId of the WLO collection that holds the launcher "skills".
# When set, GET /api/collection with no `nodeId` defaults to it, so the launcher
# can offer skills without hardcoding the id. Each skill is delivered via its
# anonymous downloadUrl. Unset → callers must pass an explicit ?nodeId=.
#
# IMPORTANT: a skill must be a REAL uploaded file (upload the .md as the node's
# content), NOT a web-link node (ccm:wwwurl). For a link node the download URL
# returns the cached HTML of the linked page, not the raw Markdown — verified
# live: a true upload returns the raw binary with its real content-type; a link
# node returns the target page.
# WLO_SKILLS_COLLECTION_ID=

# HTTP server port (only for Docker / self-hosted HTTP mode)
PORT=3000

# Optional: MIME type for the inlined Apps-SDK widget resources. Default is the
# current MCP-Apps standard `text/html;profile=mcp-app` (portable across hosts).
# Set to `text/html+skybridge` if a legacy ChatGPT runtime does not render the
# widgets with the standard value. Default: text/html;profile=mcp-app
# WLO_WIDGET_MIME=text/html;profile=mcp-app

# Optional: app identity domain for the ChatGPT plugin submission (required +
# unique per app there; widgets render under
# <domain>.web-sandbox.oaiusercontent.com). When set, it is emitted as the
# STANDARD `_meta.ui.domain` AND the `openai/widgetDomain` alias; when unset,
# only the alias — Claude's MCP-Apps host validates `ui.domain` against its own
# sandbox format and rejects widgets carrying foreign values, so leave this
# unset for Claude and set it only for a ChatGPT submission.
# WLO_WIDGET_DOMAIN=https://mcp.wirlernenonline.de

# Optional (HTTP mode): MCP response transport. Unset/false = single JSON body
# (default; maximal client compatibility — curl, IDE integrations, Vercel).
# Truthy (1/true/yes) = real Server-Sent-Events streaming, required by ChatGPT
# developer mode on the self-hosted vServer. IMPORTANT: when SSE is on, the
# reverse proxy in front MUST NOT buffer the response (nginx:
# `proxy_buffering off;`) or the stream never reaches the client. The Docker
# image defaults this to 1. Default (unset): JSON mode.
# MCP_SSE=1

# Optional: candidate pool size PER search variant used for reranking in
# enhancedSearch (NOT the number of returned hits — that is maxResults).
# Smaller = faster/smaller fetches at slightly lower recall. Default 25.
# WLO_POOL_SIZE=25

# Optional: per-request timeout (ms) for every upstream edu-sharing call.
# Prevents a hung backend socket from blocking a tool call. Default 10000.
# WLO_FETCH_TIMEOUT_MS=10000

# Optional (HTTP mode): max request-body size in bytes; larger POSTs get a 413.
# Caps a memory-exhaustion vector on the self-hosted HTTP path. Default 1048576 (1 MB).
# MAX_BODY_BYTES=1048576

# Optional (HTTP mode): per-IP requests/minute on the MCP endpoint; over the
# limit returns 429. /health is exempt. Set 0 to disable (e.g. behind a WAF /
# platform limiter). Default 120.
# RATE_LIMIT_RPM=120

# Optional (HTTP mode): per-IP requests/minute on the public REST endpoints
# (GET /api/*); over the limit returns 429. Tighter than RATE_LIMIT_RPM because
# it is an anonymous public surface. Set 0 to disable. Default 30.
# API_RATE_LIMIT_RPM=30

# Optional (HTTP mode): when truthy (1/true/yes), take the client IP from the
# RIGHTMOST (proxy-appended) X-Forwarded-For hop instead of the socket address —
# required for correct per-client rate limiting behind a reverse proxy (nginx,
# Vercel, …). The rightmost hop is the one your own proxy appended; the first
# hop is client-controlled and spoofable. Off by default because X-Forwarded-For
# must not be trusted on a directly-exposed server.
# TRUST_PROXY=0
