{
  "name": "wlomcp",
  "version": "1.0.0",
  "description": "WLO (WirLernenOnline) MCP Server – search OER content via AI agents",
  "type": "module",
  "engines": {
    "node": ">=20",
    "npm": ">=9"
  },
  "scripts": {
    "build": "tsc && node src/apps/widgets/build.mjs",
    "build:widgets": "node src/apps/widgets/build.mjs",
    "start": "node dist/stdio.js",
    "start:http": "node dist/http.js",
    "dev": "tsx src/stdio.ts",
    "dev:http": "tsx src/http.ts",
    "test": "node --import tsx --test \"tests/*.test.ts\"",
    "typecheck": "tsc -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5"
  }
}
